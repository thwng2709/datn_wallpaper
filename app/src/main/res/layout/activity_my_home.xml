<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:ads="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="model"
            type="com.itsthwng.twallpaper.ui.component.MainViewModel" />
    </data>

    <androidx.drawerlayout.widget.DrawerLayout
        android:id="@+id/drawer_lout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/root_lout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/color_theme_blue"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/v_pager"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/appBar"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginHorizontal="20dp"
                        android:layout_marginTop="32dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/btnMenu"
                            android:layout_width="@dimen/common_42dp"
                            android:layout_height="@dimen/common_42dp"
                            android:background="@drawable/ripple_rectangle"
                            android:onClick="@{() ->model.onTabClick(4)}"
                            android:padding="@dimen/common_10dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_menu"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/color_text_primary" />

                        <View
                            android:id="@+id/notification_dot"
                            android:layout_width="10dp"
                            android:layout_height="8dp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/dot_missing_permission"
                            app:layout_constraintEnd_toEndOf="@+id/btnMenu"
                            app:layout_constraintTop_toTopOf="@+id/btnMenu" />

                        <ImageView
                            android:id="@+id/logo_img"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:padding="5dp"
                            android:src="@mipmap/ic_launcher"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/btn_search"
                            android:layout_width="@dimen/common_42dp"
                            android:layout_height="@dimen/common_42dp"
                            android:background="@drawable/ripple_rectangle"
                            android:padding="@dimen/common_10dp"
                            android:paddingVertical="5dp"
                            android:src="@drawable/ic_search"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/color_text_primary" />


                    </androidx.constraintlayout.widget.ConstraintLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:orientation="vertical">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/root"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="20dp"
                            android:layout_marginBottom="20dp"
                            android:outlineSpotShadowColor="@color/transparent"
                            app:cardBackgroundColor="@color/transparent"
                            app:cardCornerRadius="500dp"
                            tools:targetApi="p">

                            <eightbitlab.com.blurview.BlurView
                                android:id="@+id/blurView"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:elevation="16dp"
                                app:blurOverlayColor="@color/color_blur_25">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="60dp"
                                    android:layout_margin="5dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">


                                    <RelativeLayout
                                        android:id="@+id/parent_home"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <View
                                            android:id="@+id/lout_home"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:layout_centerInParent="true"
                                            android:background="@drawable/bg_round_corner_500"
                                            android:backgroundTint="@color/color_theme_blue" />

                                        <LinearLayout
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_centerInParent="true"
                                            android:gravity="center"
                                            android:orientation="vertical">

                                            <ImageView
                                                android:id="@+id/img_1"
                                                android:layout_width="25dp"
                                                android:layout_height="25dp"
                                                android:src="@drawable/ic_image" />

                                            <TextView
                                                android:id="@+id/txt_home"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:fontFamily="@font/sf_pro_medium"
                                                android:text="@string/str_home"
                                                android:textColor="@color/white"
                                                android:textSize="12sp"
                                                android:visibility="gone" />

                                        </LinearLayout>

                                    </RelativeLayout>

                                    <RelativeLayout
                                        android:id="@+id/parent_cat"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@drawable/bg_round_corner_500"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <View
                                            android:id="@+id/lout_cat"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:layout_centerInParent="true"
                                            android:background="@drawable/bg_round_corner_500" />

                                        <LinearLayout
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_centerInParent="true"
                                            android:gravity="center"
                                            android:orientation="vertical">

                                            <ImageView
                                                android:layout_width="25dp"
                                                android:layout_height="25dp"
                                                android:src="@drawable/ic_category" />

                                            <TextView
                                                android:id="@+id/txt_category"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:fontFamily="@font/sf_pro_medium"
                                                android:text="@string/str_category"
                                                android:textColor="@color/white"
                                                android:textSize="12sp"
                                                android:visibility="gone" />

                                        </LinearLayout>

                                    </RelativeLayout>

                                    <RelativeLayout
                                        android:id="@+id/parent_zipper"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@drawable/bg_round_corner_500"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <View
                                            android:id="@+id/lout_zipper"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:layout_centerInParent="true"
                                            android:background="@drawable/bg_round_corner_500" />

                                        <LinearLayout
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_centerInParent="true"
                                            android:gravity="center"
                                            android:orientation="vertical">

                                            <ImageView
                                                android:layout_width="25dp"
                                                android:layout_height="25dp"
                                                android:src="@drawable/ic_zipper" />

                                            <TextView
                                                android:id="@+id/txt_zipper"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:fontFamily="@font/sf_pro_medium"
                                                android:text="@string/str_zipper"
                                                android:textColor="@color/white"
                                                android:textSize="12sp"
                                                android:visibility="gone" />

                                        </LinearLayout>

                                    </RelativeLayout>

                                    <RelativeLayout
                                        android:id="@+id/parent_fav"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@drawable/bg_round_corner_500"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <View
                                            android:id="@+id/lout_fav"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:layout_centerInParent="true"
                                            android:background="@drawable/bg_round_corner_500" />

                                        <LinearLayout
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_centerInParent="true"
                                            android:gravity="center"
                                            android:orientation="vertical">

                                            <ImageView
                                                android:layout_width="25dp"
                                                android:layout_height="25dp"
                                                android:src="@drawable/ic_fav" />

                                            <TextView
                                                android:id="@+id/txt_favourite"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:fontFamily="@font/sf_pro_medium"
                                                android:text="@string/favourite"
                                                android:textColor="@color/white"
                                                android:textSize="12sp"
                                                android:visibility="gone" />

                                        </LinearLayout>

                                    </RelativeLayout>

                                    <RelativeLayout
                                        android:id="@+id/parent_history"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@drawable/bg_round_corner_500"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <View
                                            android:id="@+id/lout_his"
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:layout_centerInParent="true"
                                            android:background="@drawable/bg_round_corner_500" />

                                        <LinearLayout
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_centerInParent="true"
                                            android:gravity="center"
                                            android:orientation="vertical">

                                            <ImageView
                                                android:layout_width="25dp"
                                                android:layout_height="25dp"
                                                android:src="@drawable/ic_history"
                                                app:tint="@color/white" />

                                            <TextView
                                                android:id="@+id/txt_history"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:fontFamily="@font/sf_pro_medium"
                                                android:text="@string/history"
                                                android:textColor="@color/white"
                                                android:textSize="12sp"
                                                android:visibility="gone" />

                                        </LinearLayout>

                                    </RelativeLayout>
                                </LinearLayout>
                            </eightbitlab.com.blurview.BlurView>
                        </androidx.cardview.widget.CardView>

                        <View
                            android:id="@+id/emptyViewNav"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:visibility="gone" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/lout_loader"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/black_2"
                        android:gravity="center"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <include layout="@layout/layout_loader" />

                    </LinearLayout>
                </RelativeLayout>

            </LinearLayout>

            <eightbitlab.com.blurview.BlurView
                android:id="@+id/fullscreen_blur"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />
        </FrameLayout>

        <com.google.android.material.navigation.NavigationView
            android:id="@+id/nav"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:background="@color/transparent">

            <include
                android:id="@+id/nav_bar"
                layout="@layout/lout_nav_bar"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </com.google.android.material.navigation.NavigationView>
    </androidx.drawerlayout.widget.DrawerLayout>
</layout>