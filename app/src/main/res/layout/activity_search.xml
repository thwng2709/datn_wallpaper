<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="model"
            type="com.itsthwng.twallpaper.ui.component.search.viewModel.SearchViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_theme_blue"
        android:orientation="vertical"
        tools:context=".activity.SearchActivity">

        <LinearLayout
            android:id="@+id/llSearchBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="@dimen/common_42dp"
            android:layout_marginEnd="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="@dimen/common_40dp"
                android:layout_height="@dimen/common_40dp"
                android:layout_gravity="center_vertical"
                android:focusable="true"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/ripple_rectangle"
                app:tint="@color/color_text_primary" />


            <EditText
                android:id="@+id/et_search"
                style="@style/EditTextLocal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_round_corner_500"
                android:backgroundTint="@color/white_30"
                android:gravity="start"
                android:hint="@string/search_here"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:src="@mipmap/ic_launcher"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_hint"
                android:textSize="@dimen/ts_16"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionSearch"
                tools:text="dvhduhv" />


            <ImageView
                android:id="@+id/btn_filter"
                android:layout_width="@dimen/common_40dp"
                android:layout_height="@dimen/common_40dp"
                android:padding="10dp"
                android:background="@drawable/ripple_rectangle"
                android:src="@drawable/ic_filter"
                app:tint="@color/color_text_primary" />


        </LinearLayout>

        <!-- Filter Indicator -->
        <LinearLayout
            android:id="@+id/chipActiveFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="60dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_round_corner_500"
            android:backgroundTint="@color/white_30"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:visibility="gone">
            
            <ImageView
                android:id="@+id/ivFilterIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_filter"
                app:tint="@color/color_text_primary" />
                
            <TextView
                android:id="@+id/tvFilterText"
                style="@style/TextViewLocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/sf_pro_medium"
                android:text="@string/all_wallpaper"
                android:textColor="@color/color_text_primary"
                android:textSize="14sp" />
                
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="15dp">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/nested_scroll_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none"
                app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_image_by_category"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adapter="@{model.wallpaperAdapter}"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"
                    tools:itemCount="4"
                    tools:listitem="@layout/item_home_image_by_cat"
                    tools:visibility="gone" />

                    <ProgressBar
                        android:id="@+id/progress_load_more"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminateTint="@color/color_theme_purple_dark">

                    </ProgressBar>
                </LinearLayout>


            </androidx.core.widget.NestedScrollView>

            <LinearLayout
                android:id="@+id/tv_no_data"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tv_no_data_for"
                    style="@style/TextViewLocal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/sf_pro_medium"
                    android:text="@string/no_data_for"
                    android:textColor="@color/white_30"
                    android:textSize="@dimen/text_size_16sp" />

                <TextView
                    android:id="@+id/tv_search_word"
                    style="@style/TextViewLocal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/sf_pro_medium"
                    android:text='@{"\""+model.searchWord+"\""}'
                    android:textColor="@color/white_30"
                    android:textSize="@dimen/text_size_16sp"
                    tools:text="more" />

            </LinearLayout>

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/sihmmer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <include layout="@layout/shimmer_home" />

            </com.facebook.shimmer.ShimmerFrameLayout>


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/noInternetLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:background="@color/color_theme_blue"
                android:layout_marginBottom="@dimen/common_50dp">

                <FrameLayout
                    android:id="@+id/illustrationImageContainer"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/bg_internet_disconnect"
                        android:layout_gravity="center"/>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvNoInternetImage"
                    style="@style/BottomSheetTextTitle"
                    android:layout_marginTop="8dp"
                    android:text="@string/no_internet_connection"
                    android:textSize="@dimen/text_size_18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.497"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/illustrationImageContainer" />

                <!-- Allow Access Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnRetry"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_button_primary_with_shadow"
                    android:fontFamily="@font/sf_pro_medium"
                    android:gravity="center"
                    android:text="@string/str_retry"
                    android:textAllCaps="false"
                    android:textColor="@color/black_02"
                    android:textSize="@dimen/text_size_16sp"
                    android:layout_marginTop="@dimen/common_12dp"
                    app:layout_constraintEnd_toEndOf="@id/btnSetting"
                    app:layout_constraintStart_toStartOf="@id/btnSetting"
                    app:layout_constraintTop_toBottomOf="@+id/tvNoInternetImage"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSetting"
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:paddingHorizontal="@dimen/common_24dp"
                    android:background="@drawable/bg_button_primary_with_shadow"
                    android:fontFamily="@font/sf_pro_medium"
                    android:gravity="center"
                    android:text="@string/reconnect"
                    android:textAllCaps="false"
                    android:textColor="@color/black_02"
                    android:textSize="@dimen/text_size_16sp"
                    android:layout_marginTop="@dimen/common_12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/btnRetry"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </RelativeLayout>

    </LinearLayout>
</layout>