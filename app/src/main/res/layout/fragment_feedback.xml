<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="feedbackFragment"
            type="com.itsthwng.twallpaper.ui.component.setting.view.feedback.FeedbackFragment" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_permission">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/toolbarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/common_8dp"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/common_16dp"
            android:layout_marginTop="@dimen/common_42dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/common_40dp"
                android:layout_height="@dimen/common_40dp"
                android:layout_gravity="center_vertical"
                android:focusable="true"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:background="@drawable/ripple_rectangle"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <com.itsthwng.twallpaper.ui.component.customView.autofit.AutoResizeTextView
                android:id="@+id/heading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/sf_pro_semi_bold"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/feedback"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_20sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_permission">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Problem type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/common_20dp"
                    android:fontFamily="@font/sf_pro_bold"
                    android:text="@string/problem_type"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/rgProblemType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/common_20dp"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/txtSuggestions"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_feedback_radio_selector"
                        android:button="@null"
                        android:checked="true"
                        android:fontFamily="@font/sf_pro_medium"
                        android:gravity="center"
                        android:padding="@dimen/common_20dp"
                        android:text="@string/suggestions"
                        android:textColor="@drawable/color_feedback_radio_text"
                        android:textSize="@dimen/text_size_14sp" />

                    <CheckBox
                        android:id="@+id/txtBugs"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/common_6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_feedback_radio_selector"
                        android:button="@null"
                        android:fontFamily="@font/sf_pro_medium"
                        android:gravity="center"
                        android:padding="@dimen/common_20dp"
                        android:text="@string/bugs"
                        android:textColor="@drawable/color_feedback_radio_text"
                        android:textSize="@dimen/text_size_14sp" />
                </LinearLayout>

                <CheckBox
                    android:id="@+id/txtOthers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/common_20dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_feedback_radio_selector"
                    android:button="@null"
                    android:fontFamily="@font/sf_pro_medium"
                    android:gravity="center"
                    android:padding="@dimen/common_20dp"
                    android:text="@string/others"
                    android:textColor="@drawable/color_feedback_radio_text"
                    android:textSize="@dimen/text_size_14sp" />

                <!-- Content -->
                <TextView
                    android:id="@+id/txtContent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/common_20dp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/sf_pro_bold"
                    android:text="@string/content"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtContent"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginHorizontal="@dimen/common_20dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_feed_back_component"
                    android:fontFamily="@font/sf_pro_medium"
                    android:gravity="top|start"
                    android:hint="@string/hint_content_description"
                    android:inputType="textMultiLine"
                    android:paddingHorizontal="@dimen/common_16dp"
                    android:paddingVertical="@dimen/common_12dp"
                    android:scrollbars="vertical"
                    android:scrollbarStyle="outsideOverlay"
                    android:isScrollContainer="true"
                    android:overScrollMode="always"
                    android:textSize="@dimen/text_size_14sp" />

                <TextView
                    android:id="@+id/tvCharCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/common_20dp"
                    android:layout_marginTop="4dp"
                    android:layout_gravity="end"
                    android:fontFamily="@font/sf_pro_regular"
                    android:text="@string/default_char_lenght_2000"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_12sp" />

                <!-- Image upload -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/layoutSelectImage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/common_20dp"
                        android:layout_marginVertical="@dimen/common_10dp"
                        android:background="@drawable/bg_feed_back_component"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/common_24dp"
                        android:paddingVertical="@dimen/common_20dp">

                        <ImageView
                            android:id="@+id/imgAddPhoto"
                            android:layout_width="@dimen/common_26dp"
                            android:layout_height="@dimen/common_24dp"
                            android:src="@drawable/ic_picture" />

                        <TextView
                            android:id="@+id/tvPhotoCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="@dimen/common_4dp"
                            android:text="@string/default_image_length_3" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="@dimen/common_10dp"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:orientation="horizontal"
                        />
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/splash_continue_button_height"
                    android:layout_marginHorizontal="@dimen/common_80dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="@dimen/common_50dp">

                    <TextView
                        android:id="@+id/btnSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/sf_pro_medium"
                        android:text="@string/str_submit"
                        android:textAllCaps="false"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:paddingLeft="55dp"
                        android:paddingRight="55dp"
                        android:paddingVertical="@dimen/common_8dp"
                        android:textColor="@color/black_02"
                        android:textSize="@dimen/text_size_16sp" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</layout>