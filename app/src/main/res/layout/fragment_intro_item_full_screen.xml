<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <FrameLayout
                android:id="@+id/defaultLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">
                <include
                    android:id="@+id/fullScreenDefaultView"
                    layout="@layout/fragment_onboarding_default"/>
            </FrameLayout>

            <TextView
                android:layout_gravity="end"
                android:id="@+id/btnSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/common_40dp"
                android:layout_marginEnd="@dimen/common_8dp"
                style="@style/ButtonNextStyle"
                android:backgroundTint="@color/colorPrimaryDark"
                android:elevation="@dimen/common_8dp"
                android:paddingHorizontal="@dimen/common_12dp"
                android:paddingVertical="@dimen/common_8dp"
                android:text="@string/skip_ads"
                android:textColor="@color/white"
                android:textSize="14sp" />

        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>