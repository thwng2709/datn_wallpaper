<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <import type="com.itsthwng.twallpaper.utils.Global" />

        <variable
            name="is_fav"
            type="Boolean" />

        <variable
            name="model"
            type="com.itsthwng.twallpaper.data.model.SettingData.WallpapersItem" />
    </data>


    <androidx.cardview.widget.CardView
        android:id="@+id/card_wall"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:backgroundTint="@color/transparent"
        app:cardCornerRadius="30dp">

        <RelativeLayout
            android:id="@+id/root_lout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"


            android:background="@color/transparent"
            android:orientation="vertical">


            <androidx.constraintlayout.utils.widget.ImageFilterView
                android:id="@+id/img_wall"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                app:image_url="@{model.wallpaperType==0?model.thumbnail:model.thumbnail}"

                tools:src="@drawable/ic_app_water_reminder" />

            <TextView
                style="@style/TextViewLocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/layoutIcon"
                android:layout_marginStart="15dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="15dp"
                android:layout_marginBottom="15dp"
                android:background="@drawable/bg_button_161621_corner_26"
                android:paddingHorizontal="20dp"
                android:paddingVertical="5dp"
                android:text="@string/live"
                android:textSize="@dimen/ts_15"
                android:visibility="gone"
                tools:visibility="gone" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/common_15dp"
                android:layout_alignParentEnd="true">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="@dimen/common_40dp"
                    android:layout_marginStart="15dp"
                    android:layout_marginEnd="15dp"
                    android:background="@drawable/bg_button_161621_corner_26"
                    android:visibility="@{model.wallpaperType==0?View.GONE:View.VISIBLE}"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toStartOf="@id/llCoin"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="10dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_live"
                        app:tint="@color/white" />
                </FrameLayout>


                <LinearLayout
                    android:id="@+id/llCoin"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/common_40dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:gravity="center"
                    android:layout_marginEnd="15dp"
                    android:paddingVertical="@dimen/common_4dp"
                    android:paddingHorizontal="@dimen/common_8dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_button_161621_corner_26"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/common_16dp"
                        android:layout_height="@dimen/common_16dp"
                        android:src="@drawable/ic_coin"
                        android:layout_marginEnd="@dimen/common_4dp"/>

                    <TextView
                        android:id="@+id/tvCurrentCoins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="50"
                        android:text="0"
                        android:fontFamily="@font/sf_pro_medium"
                        android:textSize="16sp"
                        android:textColor="@color/white" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>




            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentBottom="true"
                android:layout_margin="15dp">

                <ImageView
                    android:id="@+id/btnIconPremium"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_round_corner_500"
                    android:backgroundTint="@color/color_theme_blue"
                    android:padding="10dp"
                    android:src="@drawable/ic_pro"
                    android:visibility="@{model.accessType==0?View.VISIBLE:View.GONE}" />

                <ImageView
                    android:id="@+id/btnIconLock"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_round_corner_500"
                    android:backgroundTint="@color/white"
                    android:padding="10dp"
                    android:src="@drawable/ic_lock"
                    android:visibility="@{model.accessType==1?View.VISIBLE:View.GONE}"
                    app:tint="@color/color_text_tertiary" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_margin="15dp"
                android:background="@drawable/bg_round_corner_500"
                android:backgroundTint="@color/white">

                <ImageView
                    android:id="@+id/ic_fav_no"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_fav"
                    android:visibility="@{is_fav?View.GONE:View.VISIBLE}"
                    app:tint="@color/color_text_tertiary" />

                <ImageView
                    android:id="@+id/ic_fav_yes"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_fav_yes"

                    android:visibility="@{is_fav?View.VISIBLE:View.GONE}" />

            </RelativeLayout>


        </RelativeLayout>


    </androidx.cardview.widget.CardView>


</layout>