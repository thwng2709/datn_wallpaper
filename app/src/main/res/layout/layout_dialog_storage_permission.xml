<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/common_16dp"
        android:background="@drawable/dialog_background"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/common_16dp">


        <!-- Text mô tả -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/sf_pro_bold"
            android:text="@string/permission_denied_title"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_16sp"
            tools:layout_editor_absoluteX="@dimen/dp_16"
            app:layout_constraintTop_toTopOf="parent"/>


        <!-- Text mô tả -->
        <TextView
            android:id="@+id/tv_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_8dp"
            android:fontFamily="@font/sf_pro_medium"
            android:text="@string/permission_denied_msg"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_14sp"
            app:layout_constraintTop_toBottomOf="@+id/tvTitle"
            tools:layout_editor_absoluteX="@dimen/dp_16" />

        <!-- Buttons row: dùng chain -->
        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:layout_marginStart="@dimen/common_16dp"
            android:layout_marginEnd="@dimen/common_8dp"
            android:background="@drawable/bg_button_secondary_permission"
            android:fontFamily="@font/sf_pro_semi_bold"
            android:gravity="center"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/color_text_secondary_button"
            android:textSize="16sp"
            android:minWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/tv_description"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnOk" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnOk"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:layout_marginStart="@dimen/common_8dp"
            android:layout_marginEnd="@dimen/common_16dp"
            android:background="@drawable/bg_button_primary_with_shadow"
            android:fontFamily="@font/sf_pro_semi_bold"
            android:gravity="center"
            android:text="@string/go_to_settings"
            android:textAllCaps="false"
            android:textColor="@color/black_02"
            android:textSize="16sp"
            android:minWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/tv_description"
            app:layout_constraintStart_toEndOf="@id/btnCancel"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tùy chọn: ép chain chia đều -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_dummy"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintHorizontal_chainStyle="spread" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>