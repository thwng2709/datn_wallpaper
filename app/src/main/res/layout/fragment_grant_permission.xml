<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/black_02"
        android:fitsSystemWindows="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/common_8dp"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/common_16dp"
            android:layout_marginTop="@dimen/common_42dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/common_40dp"
                android:layout_height="@dimen/common_40dp"
                android:layout_gravity="center_vertical"
                android:focusable="true"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:background="@drawable/ripple_rectangle"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/heading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/sf_pro_semi_bold"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/grant_permission_title"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_20sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <!-- Main Container with exact spacing -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="32dp">

                <!-- Illustration Container -->
                <FrameLayout
                    android:id="@+id/illustration_container"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="0dp">

                    <ImageView
                        android:id="@+id/img_illustration"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/grant_permission"
                        android:layout_gravity="center"
                        android:scaleType="centerInside"
                        android:padding="20dp"/>
                </FrameLayout>

                <!-- Content Section with 24dp gap -->
                <LinearLayout
                    android:id="@+id/content_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp">

                    <!-- Title -->
                    <TextView
                        android:id="@+id/txt_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/permission_title"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:fontFamily="@font/sf_pro_bold"
                        android:gravity="center"/>

                    <!-- Description with 8dp gap -->
                    <TextView
                        android:id="@+id/txt_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_grant_permission"
                        android:layout_marginHorizontal="32dp"
                        android:textColor="@color/color_text_permission_desc"
                        android:textSize="14sp"
                        android:fontFamily="@font/sf_pro_regular"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- Permission Items Container with 24dp gap -->
                <LinearLayout
                    android:id="@+id/permission_list_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="32dp">

                    <!-- Overlay Permission Item -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#1A8B5CF6">

                        <LinearLayout
                            android:id="@+id/item_overlay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/overlay_permission_title"
                                    android:textColor="@color/white"
                                    android:textSize="15sp"
                                    android:fontFamily="@font/sf_pro_semi_bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/overlay_permission_subtitle"
                                    android:textColor="#B3FFFFFF"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/sf_pro_regular"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <androidx.appcompat.widget.SwitchCompat
                                    android:id="@+id/swOverlay"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"

                                    android:thumb="@drawable/switch_thumb_custom_zipper"
                                    app:track="@drawable/switch_track_custom_zipper"
                                    android:checked="false"/>

                                <TextView
                                    android:id="@+id/tvOverlayAllowed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/allowed"
                                    android:textColor="#8B5CF6"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/sf_pro_semi_bold"
                                    android:visibility="gone"/>
                            </FrameLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Manage Files Permission Item -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_manage_files"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        android:visibility="gone"
                        app:cardBackgroundColor="#1A8B5CF6">

                        <LinearLayout
                            android:id="@+id/item_manage_files"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/manage_files_permission"
                                    android:textColor="@color/white"
                                    android:textSize="15sp"
                                    android:fontFamily="@font/sf_pro_semi_bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/manage_files_permission_subtitle"
                                    android:textColor="#B3FFFFFF"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/sf_pro_regular"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <androidx.appcompat.widget.SwitchCompat
                                    android:id="@+id/sw_manage_file"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"

                                    android:thumb="@drawable/switch_thumb_custom_zipper"
                                    app:track="@drawable/switch_track_custom_zipper"
                                    android:checked="true"/>

                                <TextView
                                    android:id="@+id/tvManageFileAllowed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/allowed"
                                    android:textColor="#8B5CF6"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/sf_pro_semi_bold"
                                    android:visibility="gone"/>
                            </FrameLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Notification Permission Item -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#1A8B5CF6">

                        <LinearLayout
                            android:id="@+id/item_notification"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/notification_permission"
                                    android:textColor="@color/white"
                                    android:textSize="15sp"
                                    android:fontFamily="@font/sf_pro_semi_bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/notification_permission_subtitle"
                                    android:textColor="#B3FFFFFF"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/sf_pro_regular"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <androidx.appcompat.widget.SwitchCompat
                                    android:id="@+id/swNotification"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"

                                    android:thumb="@drawable/switch_thumb_custom_zipper"
                                    app:track="@drawable/switch_track_custom_zipper"
                                    android:checked="true"/>

                                <TextView
                                    android:id="@+id/tvNotificationAllowed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/allowed"
                                    android:textColor="#8B5CF6"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/sf_pro_semi_bold"
                                    android:visibility="gone"/>
                            </FrameLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Write Storage Permission Item -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_write_storage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#1A8B5CF6">

                        <LinearLayout
                            android:id="@+id/item_write_storage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/write_storage_permission"
                                    android:textColor="@color/white"
                                    android:textSize="15sp"
                                    android:fontFamily="@font/sf_pro_semi_bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/write_storage_permission_subtitle"
                                    android:textColor="#B3FFFFFF"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/sf_pro_regular"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <androidx.appcompat.widget.SwitchCompat
                                    android:id="@+id/swSaveAsPermission"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"

                                    android:thumb="@drawable/switch_thumb_custom_zipper"
                                    app:track="@drawable/switch_track_custom_zipper"
                                    android:checked="true"/>

                                <TextView
                                    android:id="@+id/tvSaveAsPermissionAllowed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/allowed"
                                    android:textColor="#8B5CF6"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/sf_pro_semi_bold"
                                    android:visibility="gone"/>
                            </FrameLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Battery Optimization Item -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#1A8B5CF6">

                        <LinearLayout
                            android:id="@+id/item_battery"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/battery_optimization_title"
                                    android:textColor="@color/white"
                                    android:textSize="15sp"
                                    android:fontFamily="@font/sf_pro_semi_bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/battery_optimization_subtitle"
                                    android:textColor="#B3FFFFFF"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/sf_pro_regular"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <androidx.appcompat.widget.SwitchCompat
                                    android:id="@+id/swBattery"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"

                                    android:thumb="@drawable/switch_thumb_custom_zipper"
                                    app:track="@drawable/switch_track_custom_zipper"
                                    android:checked="false"/>

                                <TextView
                                    android:id="@+id/tvBatteryAllowed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/allowed"
                                    android:textColor="#8B5CF6"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/sf_pro_semi_bold"
                                    android:visibility="gone"/>
                            </FrameLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</layout>