<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/splash_bg"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/llViewSpam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="@dimen/common_150dp"
                    android:layout_height="@dimen/common_150dp"
                    android:layout_marginHorizontal="@dimen/common_120dp"
                    android:layout_marginBottom="@dimen/common_24dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_splash"
                    app:shapeAppearanceOverlay="@style/CircleShape" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/outfitextrabold"
                    android:gravity="center"
                    android:text="@string/app_name"
                    android:textColor="@color/black_02"
                    android:textSize="@dimen/common_24dp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="@dimen/common_24dp"
                android:layout_height="@dimen/common_24dp"
                android:layout_marginBottom="@dimen/common_16dp"
                app:layout_constraintBottom_toTopOf="@+id/tvCreateBy"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvCreateBy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/common_24dp"
                android:fontFamily="@font/sf_pro_bold"
                android:gravity="center"
                android:text="@string/creator"
                android:textColor="@color/black_02"
                android:textSize="@dimen/common_16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />


        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

</layout>