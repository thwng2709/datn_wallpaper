<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_02"
        android:orientation="vertical"
        android:fitsSystemWindows="true">

        <!-- Main Container -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="60dp"
                android:gravity="center">

                <!-- Illustration Container -->
                <FrameLayout
                    android:id="@+id/illustrationContainer"
                    android:layout_width="match_parent"
                    android:layout_height="280dp">

                    <ImageView
                        android:id="@+id/img_intro"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/notification_permission"
                        android:layout_gravity="center"/>
                </FrameLayout>

                <!-- Content Section with 24dp gap from illustration -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp"
                    android:gravity="center_horizontal">

                    <!-- Title -->
                    <TextView
                        android:id="@+id/txt_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/sf_pro_bold"
                        android:text="@string/notification_permission"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <!-- Description with 8dp gap from title -->
                    <TextView
                        android:id="@+id/txt_msg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/sf_pro_regular"
                        android:gravity="center"
                        android:layout_marginHorizontal="32dp"
                        android:lineSpacingMultiplier="1.4"
                        android:text="@string/notification_permission_desc"
                        android:textColor="@color/color_text_permission_desc"
                        android:textSize="14sp"/>

                    <!-- Buttons Container with fixed gap from content -->
                    <LinearLayout
                        android:layout_width="230dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="24dp"
                        android:gravity="center">

                        <!-- Allow Access Button -->
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnNext"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_button_primary_with_shadow"
                            android:fontFamily="@font/sf_pro_semi_bold"
                            android:gravity="center"
                            android:text="@string/allow_access"
                            android:textAllCaps="false"
                            android:textColor="@color/black_02"
                            android:textSize="16sp"/>

                        <!-- Not Now Button with 16dp gap -->
                        <TextView
                            android:id="@+id/btnNotNow"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/bg_button_secondary_permission"
                            android:fontFamily="@font/sf_pro_semi_bold"
                            android:gravity="center"
                            android:text="@string/not_now"
                            android:textAllCaps="false"
                            android:textColor="@color/color_text_secondary_button"
                            android:textSize="16sp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</layout>