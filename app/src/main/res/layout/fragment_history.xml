<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:ads="http://schemas.android.com/tools"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        
        <variable
            name="model"
            type="com.itsthwng.twallpaper.ui.component.history.viewmodel.HistoryViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="102dp"
        android:background="@color/history_primary_bg">

        <!-- Normal Toolbar -->
        <LinearLayout
            android:id="@+id/normalToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:padding="5dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/ripple_circle"
                app:tint="@color/color_text_primary" />

            <TextView
                android:id="@+id/titleText"
                style="@style/TextViewLocal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/sf_pro_medium"
                android:text="@string/history"
                android:textColor="@color/color_text_primary"
                android:textSize="18sp" />
                
            <ImageView
                android:id="@+id/btnSearch"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:padding="5dp"
                android:src="@drawable/ic_search"
                android:background="@drawable/ripple_circle"
                app:tint="@color/color_text_primary" />

            <!--temp díable selection mode  -->
<!--            <ImageView-->
<!--                android:id="@+id/btnMenu"-->
<!--                android:layout_width="30dp"-->
<!--                android:layout_height="30dp"-->
<!--                android:layout_marginStart="10dp"-->
<!--                android:padding="5dp"-->
<!--                android:src="@drawable/ic_menu_dots"-->
<!--                android:background="@drawable/ripple_circle"-->
<!--                app:tint="@color/color_text_primary" />-->
        </LinearLayout>
        
        <!-- Selection Mode Toolbar -->
        <LinearLayout
            android:id="@+id/selectionToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:visibility="gone"
            android:background="@color/history_secondary_bg">

            <ImageView
                android:id="@+id/btnCloseSelection"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:padding="5dp"
                android:src="@drawable/ic_round_close"
                android:background="@drawable/ripple_circle"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/selectedCountText"
                style="@style/TextViewLocal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/sf_pro_medium"
                android:text="0 selected"
                android:textColor="@color/white"
                android:textSize="18sp"
                tools:text="3 selected" />
                
            <ImageView
                android:id="@+id/btnSelectAll"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:padding="5dp"
                android:src="@drawable/ic_select_all"
                android:background="@drawable/ripple_circle"
                app:tint="@color/white" />
                
            <ImageView
                android:id="@+id/btnDeleteSelected"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="10dp"
                android:padding="5dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/ripple_circle"
                app:tint="@color/white" />
        </LinearLayout>
        
        <EditText
            android:id="@+id/searchEditText"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_search_border"
            android:hint="@string/search_here"
            android:paddingHorizontal="16dp"
            android:textColor="@color/color_text_primary"
            android:textColorHint="@color/color_text_secondary"
            android:textSize="14sp"
            android:visibility="gone"
            android:fontFamily="@font/sf_pro_medium"
            android:inputType="text"
            android:imeOptions="actionSearch" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:paddingHorizontal="20dp"
                    android:gravity="center"
                    android:text="@string/all"
                    android:background="@drawable/ripple_chip_selected"
                    android:textColor="@color/white"
                    android:fontFamily="@font/sf_pro_medium"
                    android:textSize="14sp"
                    android:elevation="4dp" />

                <TextView
                    android:id="@+id/chipHome"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/ripple_chip"
                    android:fontFamily="@font/sf_pro_medium"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:text="@string/home_screen"
                    android:textColor="@color/color_text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/chipLock"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:layout_marginStart="10dp"
                    android:paddingHorizontal="20dp"
                    android:gravity="center"
                    android:text="@string/lock_screen"
                    android:background="@drawable/ripple_chip"
                    android:textColor="@color/color_text_primary"
                    android:fontFamily="@font/sf_pro_medium"
                    android:textSize="14sp" />

            </LinearLayout>
        </HorizontalScrollView>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Shimmer Loading Layout -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                app:shimmer_auto_start="true"
                app:shimmer_base_alpha="0.7"
                app:shimmer_duration="1500"
                app:shimmer_repeat_count="@android:integer/config_shortAnimTime"
                app:shimmer_repeat_delay="500">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="10dp">

                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <androidx.constraintlayout.utils.widget.ImageFilterView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="10dp"
                            android:background="@color/color_shimmer"
                            app:round="25dp" />

                        <androidx.constraintlayout.utils.widget.ImageFilterView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:background="@color/color_shimmer"
                            app:round="25dp" />
                    </LinearLayout>

                    <!-- Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <androidx.constraintlayout.utils.widget.ImageFilterView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="10dp"
                            android:background="@color/color_shimmer"
                            app:round="25dp" />

                        <androidx.constraintlayout.utils.widget.ImageFilterView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:background="@color/color_shimmer"
                            app:round="25dp" />
                    </LinearLayout>

                    <!-- Row 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <androidx.constraintlayout.utils.widget.ImageFilterView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="10dp"
                            android:background="@color/color_shimmer"
                            app:round="25dp" />

                        <androidx.constraintlayout.utils.widget.ImageFilterView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:background="@color/color_shimmer"
                            app:round="25dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <FrameLayout
                android:id="@+id/swipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHistory"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adapter="@{model.wallpaperAdapter}"
                    android:paddingHorizontal="20dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"
                    tools:itemCount="10"
                    android:clipToPadding="false"
                    android:paddingBottom="60dp"
                    tools:listitem="@layout/item_history_wallpaper" />

            </FrameLayout>

            <LinearLayout
                android:id="@+id/loutNoHistory"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/emptyIcon"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_image"
                    app:tint="@color/color_text_secondary" />

                <TextView
                    android:id="@+id/emptyTitle"
                    style="@style/TextViewLocal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/sf_pro_medium"
                    tools:text="@string/no_history"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/emptySubtitle"
                    style="@style/TextViewLocal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginHorizontal="40dp"
                    android:gravity="center"
                    tools:text="@string/no_history_desc"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="14sp" />
                    
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardEmptyAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="4dp"
                    android:foreground="@drawable/ripple_primary_button"
                    app:cardBackgroundColor="@color/color_theme_blue">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="28dp"
                        android:paddingVertical="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_image"
                            app:tint="@color/white"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/btnEmptyAction"
                            style="@style/TextViewLocal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="@string/browse_wallpapers"
                            android:textColor="@color/white"
                            android:fontFamily="@font/sf_pro_medium"
                            android:textSize="16sp"
                            android:textAllCaps="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
            
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

    </LinearLayout>
</layout>