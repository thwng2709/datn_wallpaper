<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/common_16dp"
        android:background="@drawable/bg_bottom_sheet">

        <TextView
            android:id="@+id/txt_title_dialog_apply_click_script"
            style="@style/BottomSheetTextTitle"
            android:text="@string/write_storage_permission"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/lytContent"
            style="@style/BottomSheetTextMessage"
            android:text="@string/access_files_permission_message"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_title_dialog_apply_click_script">
        </TextView>

        <TextView
            android:id="@+id/btnConfirmYes"
            style="@style/ButtonConfirmStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/common_24dp"
            android:layout_marginBottom="@dimen/common_20dp"
            android:text="@string/mgs_ok"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/btnCancel"
            app:layout_constraintTop_toBottomOf="@+id/lytContent" />

        <TextView
            android:id="@+id/btnCancel"
            style="@style/ButtonCancelStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/common_8dp"
            android:text="@string/cancel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnConfirmYes" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
