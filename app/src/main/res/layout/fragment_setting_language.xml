                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:paddingStart="@dimen/common_40dp"
                    android:paddingEnd="@dimen/common_40dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <RadioButton
                        android:id="@+id/rbt_hindi"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/common_68dp"
                        android:layout_gravity="center"
                        android:background="@android:color/transparent"
                        android:button="@null"
                        android:drawableEnd="@drawable/ic_radio_selector"/>

                    <RadioButton
                        android:id="@+id/rbt_german"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/common_68dp"
                        android:layout_gravity="center"
