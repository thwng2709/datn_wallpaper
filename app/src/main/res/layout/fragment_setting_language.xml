<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/toolbarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/common_8dp"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/common_16dp"
            android:layout_marginTop="@dimen/common_42dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="@dimen/common_40dp"
                android:layout_height="@dimen/common_40dp"
                android:layout_gravity="center_vertical"
                android:focusable="true"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:background="@drawable/ripple_rectangle"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/black" />

            <com.itsthwng.twallpaper.ui.component.customView.autofit.AutoResizeTextView
                android:id="@+id/heading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/sf_pro_semi_bold"
                android:gravity="center"
                android:maxLines="1"
                android:layout_marginHorizontal="@dimen/common_40dp"
                android:text="@string/languages"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size_20sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <ImageView
                android:id="@+id/ivChoose"
                android:layout_width="@dimen/common_40dp"
                android:layout_height="@dimen/common_40dp"
                android:padding="@dimen/common_4dp"
                android:background="@drawable/ripple_rectangle"
                android:src="@drawable/ic_tick"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <ScrollView
            android:id="@+id/svLanguage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/common_20dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:gravity="center"
            android:paddingVertical="@dimen/common_16dp"
            android:scrollbars="none">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:id="@+id/layoutAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/common_20dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:id="@+id/itemHindi"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/common_68dp"
                        android:background="@drawable/bg_item_language"
                        android:gravity="center_vertical"
                        android:layoutDirection="locale"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/common_20dp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:layout_width="@dimen/common_40dp"
                            android:layout_height="@dimen/common_40dp"
                            android:src="@drawable/hindi_flag"
                            app:civ_border_color="@color/md_blue_gray_300"
                            app:civ_border_width="@dimen/common_1dp" />

                        <TextView
                            android:id="@+id/txtHindi"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center_vertical"
                            android:fontFamily="@font/sf_pro_regular"
                            android:gravity="start|center_vertical"
                            android:paddingHorizontal="@dimen/common_14dp"
                            android:text="@string/text_lang_hi"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text_size_14sp" />

                    </LinearLayout>

                    <LinearLayout
