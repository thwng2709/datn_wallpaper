                            android:fontFamily="@font/sf_pro_regular"
                            android:gravity="start|center_vertical"
                            android:paddingHorizontal="@dimen/common_14dp"
                            android:text="@string/text_lang_uk"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text_size_14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/itemJapanese"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/common_68dp"
                        android:layout_marginTop="@dimen/common_10dp"
                        android:background="@drawable/bg_item_language"
                        android:gravity="center_vertical"
                        android:layoutDirection="locale"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/common_20dp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:layout_width="@dimen/common_40dp"
                            android:layout_height="@dimen/common_40dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/japan_flag"
                            app:civ_border_color="@color/md_blue_gray_300"
                            app:civ_border_width="@dimen/common_1dp" />

