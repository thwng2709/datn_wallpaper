                        android:button="@null"
                        android:drawableEnd="@drawable/ic_radio_selector" />

                    <RadioButton
                        android:id="@+id/rbt_vietnam"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/common_68dp"
