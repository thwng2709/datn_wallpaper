                        android:layout_width="match_parent"
                        android:layout_height="@dimen/common_68dp"
                        android:layout_marginTop="@dimen/common_10dp"
                        android:background="@drawable/bg_item_language"
                        android:gravity="center_vertical"
                        android:layoutDirection="locale"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/common_20dp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:layout_width="@dimen/common_40dp"
                            android:layout_height="@dimen/common_40dp"
                            android:src="@drawable/german_flag"
                            app:civ_border_color="@color/md_blue_gray_300"
                            app:civ_border_width="@dimen/common_1dp" />

                        <TextView
                            android:id="@+id/txtGerman"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center_vertical"
                            android:fontFamily="@font/sf_pro_medium"
                            android:gravity="start|center_vertical"
                            android:paddingHorizontal="@dimen/common_14dp"
                            android:text="@string/text_lang_de"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text_size_14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/itemSpanish"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/common_68dp"
                        android:layout_marginTop="@dimen/common_10dp"
                        android:background="@drawable/bg_item_language"
                        android:gravity="center_vertical"
                        android:layoutDirection="locale"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/common_20dp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:layout_width="@dimen/common_40dp"
                            android:layout_height="@dimen/common_40dp"
                            android:src="@drawable/span_flag"
                            app:civ_border_color="@color/md_blue_gray_300"
                            app:civ_border_width="@dimen/common_1dp" />

                        <TextView
                            android:id="@+id/txtSpanish"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center_vertical"
                            android:fontFamily="@font/sf_pro_medium"
                            android:gravity="start|center_vertical"
                            android:paddingHorizontal="@dimen/common_14dp"
                            android:text="@string/text_lang_es"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text_size_14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/itemPortuguese"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/common_68dp"
                        android:layout_marginTop="@dimen/common_10dp"
                        android:background="@drawable/bg_item_language"
                        android:gravity="center_vertical"
                        android:layoutDirection="locale"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/common_20dp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:layout_width="@dimen/common_40dp"
                            android:layout_height="@dimen/common_40dp"
                            android:src="@drawable/por_flag"
                            app:civ_border_color="@color/md_blue_gray_300"
                            app:civ_border_width="@dimen/common_1dp" />

                        <TextView
