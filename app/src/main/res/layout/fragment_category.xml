<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="model"
            type="com.itsthwng.twallpaper.ui.component.home.viewmodel.CategoryViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_theme_blue"
        android:orientation="vertical"
        android:paddingTop="92dp"
        tools:context=".fragments.CategoryFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/noInternetLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:background="@color/color_theme_blue"
            android:layout_marginBottom="@dimen/common_50dp">

            <FrameLayout
                android:id="@+id/illustrationImageContainer"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/bg_internet_disconnect"
                    android:layout_gravity="center"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvNoInternetImage"
                style="@style/BottomSheetTextTitle"
                android:layout_marginTop="8dp"
                android:text="@string/no_internet_connection"
                android:textSize="@dimen/text_size_18sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.497"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/illustrationImageContainer" />

            <!-- Allow Access Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRetry"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_button_primary_with_shadow"
                android:fontFamily="@font/sf_pro_medium"
                android:gravity="center"
                android:text="@string/str_retry"
                android:textAllCaps="false"
                android:textColor="@color/black_02"
                android:textSize="@dimen/text_size_16sp"
                android:layout_marginTop="@dimen/common_12dp"
                app:layout_constraintEnd_toEndOf="@id/btnSetting"
                app:layout_constraintStart_toStartOf="@id/btnSetting"
                app:layout_constraintTop_toBottomOf="@+id/tvNoInternetImage"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSetting"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:paddingHorizontal="@dimen/common_24dp"
                android:background="@drawable/bg_button_primary_with_shadow"
                android:fontFamily="@font/sf_pro_medium"
                android:gravity="center"
                android:text="@string/reconnect"
                android:textAllCaps="false"
                android:textColor="@color/black_02"
                android:textSize="@dimen/text_size_16sp"
                android:layout_marginTop="@dimen/common_12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnRetry"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_all"
                style="@style/TextViewLocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="@dimen/common_10dp"
                android:visibility="gone"
                android:background="@drawable/ripple_circle"
                android:layout_marginHorizontal="10dp"
                android:fontFamily="@font/sf_pro_medium"
                android:onClick="@{()->model.setSelectedType(0)}"
                android:text="@string/all"
                android:textColor="@{model.selected==0?@color/color_text_primary:@color/color_text_secondary}"
                android:textSize="@dimen/ts_15" />

            <TextView
                android:id="@+id/tv_simple"
                style="@style/TextViewLocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="@dimen/common_10dp"
                android:background="@drawable/ripple_circle"
                android:layout_marginHorizontal="10dp"
                android:fontFamily="@font/sf_pro_medium"
                android:onClick="@{()->model.setSelectedType(1)}"
                android:text="@string/simple"
                android:textColor="@{model.selected==1?@color/color_text_primary:@color/color_text_secondary}"
                android:textSize="@dimen/ts_15" />

            <TextView
                android:id="@+id/tv_Live"
                style="@style/TextViewLocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="@dimen/common_10dp"
                android:background="@drawable/ripple_circle"
                android:layout_marginHorizontal="10dp"
                android:fontFamily="@font/sf_pro_medium"
                android:onClick="@{()->model.setSelectedType(2)}"
                android:text="@string/live"
                android:textColor="@{model.selected==2?@color/color_text_primary:@color/color_text_secondary}"
                android:textSize="@dimen/ts_15"

                />

        </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_cat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="5"
                    android:clipToPadding="false"
                    android:paddingBottom="160dp"
                    tools:listitem="@layout/item_category">

                </androidx.recyclerview.widget.RecyclerView>

                <View

                    android:layout_width="0dp"
                    android:layout_height="100dp" />

                <ProgressBar
                    android:id="@+id/progressLoading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminateTint="@color/color_theme_purple_dark">

                </ProgressBar>

                <LinearLayout
                    android:id="@+id/tv_no_data"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/common_120dp"
                        android:layout_height="@dimen/common_120dp"
                        android:layout_gravity="center_horizontal"
                        android:src="@drawable/img_no_photos" />

                    <TextView
                        style="@style/TextViewLocal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:fontFamily="@font/sf_pro_medium"
                        android:text="@string/no_categories"
                        android:textColor="@color/white_30"
                        android:textSize="@dimen/ts_20" />
                </LinearLayout>
            </LinearLayout>

    </LinearLayout>
</layout>