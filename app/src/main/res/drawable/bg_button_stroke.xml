<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?attr/colorControlHighlight">
<!--    Đây là phần drawable thông thường của mình-->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/common_26dp"/>
            <stroke android:width="1.5dp"
                android:color="@color/color_DEDFE5"/>
        </shape>
    </item>

<!--    Đây là phần mask nhằm tạo hiệu ứng ripple-->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
<!--            Phần radius cần phải giống với phần trên-->
            <corners android:radius="@dimen/common_26dp"/>
<!--            Phần này là màu nháy của ripple-->
            <solid android:color="@color/white" />
        </shape>
    </item>
</ripple>