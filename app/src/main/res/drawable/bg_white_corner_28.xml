<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?attr/colorControlHighlight">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners
                android:radius="@dimen/common_28dp"/>
        </shape>
    </item>
    <!-- Mask để hiệu ứng ripple nhấp nháy -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/common_28dp" />
            <solid android:color="@color/white" /> <!-- Màu trắng là màu nhấn -->
        </shape>
    </item>
</ripple>